# ─────────────────────────────────────────────────────────────────────────────
# .env.local — NEVER commit this file
# Copy this to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# Neon PostgreSQL — pooled (app queries)
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# Neon PostgreSQL — unpooled direct (drizzle-kit migrations ONLY)
DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# Auth.js v5 — generate: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here

# App base URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Resend — magic link + reminder emails
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=Memoriza <noreply@yourdomain.com>
RESEND_WEBHOOK_SECRET=your-webhook-secret

# Cloudinary — cover image uploads
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Upstash Redis — rate limiting
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Admin
ADMIN_EMAIL=your@email.com

# Vercel Cron — protects /api/cron/reminders
CRON_SECRET=change-me-to-a-random-secret
