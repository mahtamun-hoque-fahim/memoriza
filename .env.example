# ─────────────────────────────────────────────────────────────────────────────
# .env.local — NEVER commit this file
# Copy to .env.local and fill in values from your Neon dashboard
# ─────────────────────────────────────────────────────────────────────────────

# Neon PostgreSQL — pooled connection (used by app code)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Neon PostgreSQL — direct/unpooled connection (used ONLY by drizzle-kit for migrations)
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=false

# Public base URL (used for OG tags and share links)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Salt for IP hashing — any random string, keep it secret
IP_SALT=change-me-to-a-random-secret-string

# Upstash Redis — for rate limiting on /api/create (Phase 2)
# Get from: https://console.upstash.com → Create Database → REST API
# Leave blank to disable rate limiting (fine for dev)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Resend — for sending edit link emails (Phase 3)
# Get from: https://resend.com → API Keys
# Leave blank to disable email sending (edit links still work if accessed directly)
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=Memoriza <noreply@yourdomain.com>

# Cloudinary — for cover image uploads (Phase 3)
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Clerk — authentication (Phase 4)
# Get from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Vercel Cron secret — protects /api/reminders and /api/cron/cleanup
# Set the same value in Vercel dashboard env vars
CRON_SECRET=change-me-to-a-random-secret
